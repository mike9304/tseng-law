# Public site URL
NEXT_PUBLIC_SITE_URL=https://tseng-law.com
SITE_URL=https://tseng-law.com

# Postgres for Visual CMS 2.0
DATABASE_URL=postgresql://username:password@localhost:5432/hojeong_visual_cms?schema=public

# CMS admin login
CMS_ADMIN_USERNAME=replace-with-admin-username
CMS_ADMIN_PASSWORD=replace-with-a-long-random-password
CMS_SESSION_SECRET=replace-with-a-long-random-secret

# Vercel Blob storage for live CMS publishing
BLOB_READ_WRITE_TOKEN=replace-with-vercel-blob-token

# Builder security and observability
BUILDER_ALLOWED_ORIGINS=https://tseng-law.com
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_REPLAY_SAMPLE_RATE=0.05

# AI consultation mail intake
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=replace-with-smtp-username
SMTP_PASS=replace-with-smtp-password
NOTIFY_EMAIL=replace-with-default-notify-email
CONSULTATION_NOTIFY_EMAIL=replace-with-consultation-review-email
NEXT_PUBLIC_CONSULTATION_PUBLIC_EMAIL=wei@hoveringlaw.com.tw
CONSULTATION_LOG_DIR=./runtime-data/consultation-logs

# Optional LLM provider for AI consultation
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
